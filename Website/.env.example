# No environment variables are required for the Website to run locally.
#
# The following values are hardcoded in the source (not env vars) but are
# documented here for reference in case they need to be changed.

# Formspree endpoint for the contact form
# Located in: src/components/ContactForm.tsx
# FORMSPREE_CONTACT_URL=https://formspree.io/f/YOUR_FORM_ID

# Formspree endpoint for the franchise application form
# Located in: src/app/franchise/apply/page.tsx
# FORMSPREE_FRANCHISE_URL=https://formspree.io/f/YOUR_FORM_ID

# WhatsApp phone number for ordering CTAs
# Located in: src/lib/brands.ts (getWhatsAppUrl helper)
# WHATSAPP_PHONE=595992035000
