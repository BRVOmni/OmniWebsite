# No environment variables are required for the Website to run locally,
# except for RESEND_API_KEY which is needed for form submissions.

# Resend API key (required for contact and franchise forms)
# Get yours at https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxxxxxxxxxx

# Email addresses (optional — defaults shown)
# CONTACT_EMAIL=info@omniprise.com.py
# FRANCHISE_EMAIL=franquicias@omniprise.com.py

# Sender email — must be a verified domain in Resend
# Use onboarding@resend.dev for testing (only sends to your account email)
# FROM_EMAIL=onboarding@resend.dev

# WhatsApp phone number for ordering CTAs
# Located in: src/lib/brands.ts (getWhatsAppUrl helper)
# WHATSAPP_PHONE=595992035000
